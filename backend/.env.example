# AIP Backend Environment Variables Template

# App settings
APP_NAME="Attendance Intelligence Platform"
DEBUG=true
PORT=8000
HOST="0.0.0.0"

# Database Connection
# Standard PostgreSQL URL structure: postgresql://[user]:[password]@[host]:[port]/[database]
# If using async later, this changes to: postgresql+asyncpg://...
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5432/attendance_platform"

# Security & JWT Tokens
# Generate a secure secret using: openssl rand -hex 32
SECRET_KEY="your_32_character_hex_secret_key_here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
